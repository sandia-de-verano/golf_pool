function setValues_keys(dataset, targetSheet) {
try {
  if (!dataset || dataset.length === 0) {
    Logger.log('JSON array is empty.');
    return;
  }

  const flattenedData = dataset.map(item => flattenObject(item));

  let headers = new Set();
  flattenedData.forEach(item => {
    Object.keys(item).forEach(key => headers.add(key));
  });
  
  headers = Array.from(headers);

  // 3. Convert the flattened objects into a 2D array for setValues()
  const rows = flattenedData.map(item => {
    // For each row, map the unique headers to the corresponding value in the flattened object.
    // If the key is missing in the object, use an empty string.
    return headers.map(header => (item.hasOwnProperty(header) ? item[header] : ''));
  });

  // Add the headers as the first row
  rows.unshift(headers);

