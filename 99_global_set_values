function setValues(dataset,targetSheet,headers) {
  const outputArray = [];
    outputArray.push(headers);
    outputArray.push(...dataset);
  try {
    // Determine the target range size
    const numRows = outputArray.length;
    const numCols = outputArray[0].length;

    const lastRow = targetSheet.getLastRow();
    const lastCol = targetSheet.getLastColumn();
    const targetRange = targetSheet.getRange(lastRow+1, 1, numRows, numCols);
    
    // setValues() is the fastest way to write data to a sheet.
    targetRange.setValues(outputArray);

    targetSheet.getRange(1, 1, 1, numCols).setFontWeight('bold');

    console.log("Successfully pushed %s rows and %s columns to the sheet.", numRows - 1, numCols);
    
  } catch (e) {
    Logger.log("Error in setValues: %s", e.toString());
  }

}
