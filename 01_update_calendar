function slugify(text) {
  if (!text) return "";
  return text.toString().toLowerCase()
    .replace(/\b(the|presented by|at|classic|championship|open|invitational|tournament)\b/gi, '')
    .replace(/[^a-z0-9]/g, '') // Remove all non-alphanumeric chars
    .trim();
}


function merge_golf_data_final(espnArray, dgArray) {

  const finalResults = [];
  const matchedDgIndices = new Set();
  const FUZZY_THRESHOLD = 0.7;

  // 1. Define your Default Fields
  const DEFAULTS = {
    isPoolEvent: false,
  id_tournament: '',
  id_event_espn: '',
  year: 2026,
  tournamentName: '',
  league: '',
  startDate_mt: '',
  endDate_mt: '',
  start_date: '',
  purse: 0,
  eventStatus: '',
  defChamp_id: '',
  defChamp_fullName: '',
  winner_id: '',
  winner_fullName: '',
  id_venue: '',
  venueName: '',
  location: '',
  numCompetitors: 0,
  url_event: '',
  country: '',
  course: '',
  course_key: '',
  event_id: '',
  event_name: '',
  latitude: 0,
  location: '',
  longitude: 0,
  start_date: '',
  status: '',
  tour: '',
  winner: ''
  };

const slugify = (text) => {
    if (!text) return "";
    return text.toString().toLowerCase()
      .replace(/\b(the|presented by|pres\. by|at|classic|championship|open|invitational|tournament|liv|pga|lpga|korn ferry|dp world|bmw|fedex|st|visa)\b/gi, '')
      .replace(/[^a-z0-9]/g, '')
      .trim();
  };

const getDayDiff = (d1, d2) => {
    const date1 = new Date(d1);
    const date2 = new Date(d2);
    if (isNaN(date1) || isNaN(date2)) return 999;
    return Math.abs((date1 - date2) / (1000 * 60 * 60 * 24));
  };

  // 2. Loop through ESPN Array
  espnArray.forEach((espnItem) => {
    const eName = espnItem.tournamentName || espnItem.event_name || "Unknown";
    const eDate = String(espnItem.start_date || "").substring(0, 10);
    const eSlug = slugify(eName);

    let bestMatchIndex = -1;
    let highestScore = 0;

    // 3. Search Data Golf for a partner
    for (let j = 0; j < dgArray.length; j++) {
      if (matchedDgIndices.has(j)) continue;

      const dgItem = dgArray[j];
      const dgDate = String(dgItem.start_date || "").substring(0, 10);
      
      // Match if within a 7-day window
      if (getDayDiff(eDate, dgDate) <= 7) {
        const dgName = dgItem.event_name || dgItem.name || "";
        const dgSlug = slugify(dgName);
        const score = getSimilarityScore(eSlug, dgSlug);

        if (eSlug.includes(dgSlug) || dgSlug.includes(eSlug) || score > FUZZY_THRESHOLD) {
          if (score > highestScore) {
            highestScore = score;
            bestMatchIndex = j;
          }
        }
      }
    }

    if (bestMatchIndex !== -1) {
      // --- MERGED ROW ---
      matchedDgIndices.add(bestMatchIndex);
      const dgItem = dgArray[bestMatchIndex];
      finalResults.push({
        ...DEFAULTS,
        ...espnItem, // ESPN data takes priority for structure
        ...dgItem,   // DG data fills in the gaps
        event_name: eName, // Keep the ESPN name as primary
        id_tournament: espnItem.id_tournament || DEFAULTS.id_tournament,
      });
    } else {
      // --- ESPN ONLY ---
      finalResults.push({
        ...DEFAULTS,
        ...espnItem,
        event_name: eName,
        id_tournament: espnItem.id_tournament || DEFAULTS.id_tournament,
      });
    }
  });

  // 4. Add Data Golf items that never found an ESPN partner
  dgArray.forEach((dgItem, index) => {
    if (!matchedDgIndices.has(index)) {

      finalResults.push({
        ...DEFAULTS,
        ...dgItem,
        event_name: dgItem.event_name || DEFAULTS.event_name,
        id_tournament: YEAR,
        id_event_espn: dgItem.event_id || DEFAULTS.id_event_espn,
        eventStatus: dgItem.status || DEFAULTS.eventStatus,
      });
    }
  });

  // 5. Final Sort by Date
  return finalResults.sort((a, b) => new Date(a.start_date) - new Date(b.start_date));
}

/**
 * Similarity Scoring Helpers
 */
function getSimilarityScore(s1, s2) {
  if (s1 === s2) return 1.0;
  if (!s1 || !s2) return 0;
  const longer = s1.length > s2.length ? s1 : s2;
  const shorter = s1.length > s2.length ? s2 : s1;
  return (longer.length - editDistance(longer, shorter)) / longer.length;
}

function editDistance(s1, s2) {
  let costs = [];
  for (let i = 0; i <= s1.length; i++) {
    let lastValue = i;
    for (let j = 0; j <= s2.length; j++) {
      if (i == 0) costs[j] = j;
      else if (j > 0) {
        let newValue = costs[j - 1];
        if (s1.charAt(i - 1) != s2.charAt(j - 1))
          newValue = Math.min(Math.min(newValue, lastValue), costs[j]) + 1;
        costs[j - 1] = lastValue;
        lastValue = newValue;
      }
    }
    if (i > 0) costs[s2.length] = lastValue;
  }
  return costs[s2.length];
}

function extractChampionInfo(championData){
  let champ_info;
  if (!championData) {
    champ_info = { fullName: '', id: '' };
    return champ_info;
  } else if (championData.athlete) {
    champ_info = { fullName: championData.athlete.fullName || '', id: championData.athlete.id || '' };
    return champ_info;
  } else if (championData.roster && championData.roster.entries && championData.roster.entries.length > 0) {
    // Concatenate player IDs for roster
    const ids = championData.roster.entries.map(e => e.playerId).join(', ');
    champ_info = {fullName: '', id: ids };
    return champ_info;
  } else { champ_info = {fullName: '', id: '' }};

  return champ_info

};

function fetch_url(endpoint) {
  // --- 1. Fetch Data ---
  let data;
  try {
    const response = UrlFetchApp.fetch(endpoint, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) {
      throw new Error(`HTTP Error ${response.getResponseCode()}`);
    }
    data = JSON.parse(response.getContentText());
  } catch (e) {
    console.log(`Failed to fetch DataGolf field updates: ${e.message}`);
    return;
  }
  return data
}

function batchfetch_v2(sourceDataArray,batch_size) {
  const totalRequests = sourceDataArray.length;
  const allResponses = [];

  //try {
    for (let batchStart = 0; batchStart < totalRequests; batchStart += batch_size) {
      const batchEnd = Math.min(batchStart + batch_size, totalRequests);
      const currentBatch = sourceDataArray.slice(batchStart, batchEnd);

      console.log(`Processing batch ${Math.floor(batchStart / batch_size) + 1} (${batchStart + 1} to ${batchEnd} of ${totalRequests})...`);

      // 1. Create fetch requests
      const fetchRequests = currentBatch.map(item => ({
        url: item,
        method: 'GET',
        muteHttpExceptions: true
      }));

      // 2. Perform concurrent HTTP requests for the current batch
      const responses = UrlFetchApp.fetchAll(fetchRequests);

      // 3. Merge responses back with original source data
      for (let i = 0; i < responses.length; i++) {
        const response = responses[i];
        const source = currentBatch[i];

        if (response.getResponseCode() !== 200) {
          //const errorMsg = `Fetch failed. Code: ${response.getResponseCode()}. Message: ${response.getContentText().substring(0, 100)}`;
          //console.error(`Fetch error for ${source.url_event}: ${errorMsg}`);
          continue; // Skip this item
        }

        const mergedObject = {
          source: source, // Original source data
          response: response   // The API response object
        };
        allResponses.push(mergedObject);
      }
    }
  //} catch (e) {
    //const errorMsg = `ERROR during batch fetch: ${e}`;
    //console.error(errorMsg);
  //}

  return allResponses;
}

