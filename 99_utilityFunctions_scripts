function createDgToEspnMap(rawLookupValues) {
  const DG_ID_COL_INDEX = 1; // Column B (Index 1)
  const ESPN_ID_COL_INDEX = 0; // Column A (Index 0)
  
  const dgToEspnMap = {};
  
  // Start from row 1 to skip the header row (index 0)
  for (let i = 1; i < rawLookupValues.length; i++) {
    const row = rawLookupValues[i];
    
    const dgId = row[DG_ID_COL_INDEX].toString();
    const espnId = row[ESPN_ID_COL_INDEX].toString();
    
    // Check if both IDs exist (not null/undefined/empty string after conversion)
    if (dgId && espnId) {
      dgToEspnMap[dgId] = espnId;
    }
  }
  
  return dgToEspnMap;
}

function createEspnToDgMap(rawLookupValues) {
  const DG_ID_COL_INDEX = 1; // Column B (Index 1)
  const ESPN_ID_COL_INDEX = 0; // Column A (Index 0)
  
  const espnToDgMap = {};
  
  // Start from row 1 to skip the header row (index 0)
  for (let i = 1; i < rawLookupValues.length; i++) {
    const row = rawLookupValues[i];

    // Explicitly convert IDs to strings before using them
    const dgId = row[DG_ID_COL_INDEX].toString();
    const espnId = row[ESPN_ID_COL_INDEX].toString();
    
    // Check if both IDs exist
    if (dgId && espnId) {
      espnToDgMap[espnId] = dgId;
  }
  }
  return espnToDgMap;
}

function mergeArrayData(primaryDataArray, dgMap, espnMap, mergeOn) {
  let newHeader;
  let lookupMap; 
  
  // Use the local parameter names (dgMap, espnMap) instead of global-style names
  if (mergeOn === 'id_athlete_espn') {
    newHeader = 'id_athlete_dg';
    lookupMap = espnMap;
  } else if (mergeOn === 'id_athlete_dg') {
    newHeader = 'id_athlete_espn';
    lookupMap = dgMap;
  }

  // Safety Gate: If the maps weren't passed correctly, stop here
  if (!lookupMap) {
    console.error(`mergeArrayData failed: lookupMap for ${mergeOn} is undefined.`);
    return primaryDataArray;
  }

  for (const rowObject of primaryDataArray) {
    const sourceId = rowObject[mergeOn] ? rowObject[mergeOn].toString() : '';
    const targetId = lookupMap[sourceId];
    
    rowObject[newHeader] = targetId || '';
  }
  return primaryDataArray;
}

