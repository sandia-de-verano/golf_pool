/**
 * Returns the current event configuration from the lookup sheet.
 * Consolidates the logic from getCurrentEvent, getCurrentEvent_2, and getCurrentEvent_3.
 */
function getCurrentEvent(sheet){
  try {
    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) {
      //Logger.log(`Sheet contains no data besides headers.`);
      return null;
    }

    const headers = data[0];
    const values = data.slice(1);

    const dataMapped = values.map(row => {
      return headers.reduce((obj, header, index) => {
        obj[header] = row[index];
        return obj;
      }, {});
    });
    const currentEvent = dataMapped.find(item => item.tourItem === 'current');
    if (!currentEvent || !currentEvent.url_event) {
    //console.log("getCurrentEvent: Could not find 'current' event in lookup table.");
    return null;
  }

  return currentEvent;

  } catch (e) {
    Logger.log(`Error reading data from sheet: ${e.message}`);
    return null;
  }

}

