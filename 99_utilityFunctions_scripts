/** 	Use short-circuiting to check if obj exists AND if obj[key] exists.
*		If either fails, it defaults to ''. 
*/

function safeGet(obj, key) {
  // Use short-circuiting to check if obj exists AND if obj[key] exists.get_currentEvent
  // If either fails, it defaults to ''.
  return (obj && obj[key] !== undefined) ? obj[key] : '';
}

