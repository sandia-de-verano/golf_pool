/**
 * Merges properties from a secondary array into a primary array of objects.
 * @param {Array} primary - The array you want to update.
 * @param {Array} secondary - The source of new data.
 * @param {string} joinKey - The unique ID key used to match (e.g., 'id_athlete_dg').
 * @returns {Array} The merged primary array.
 */
function merge_data(primary, secondary, joinKey) {
  if (!Array.isArray(primary) || !Array.isArray(secondary)) {
    throw new TypeError("Both inputs must be arrays.");
  }

  // 1. Create a Map of the secondary data for instant lookups
  const secondaryMap = new Map();
  secondary.forEach(obj => {
    const id = obj?.[joinKey];
    if (id !== undefined && id !== null) {
      secondaryMap.set(String(id), obj);
    }
  });

  // 2. Map over the primary array and merge data if a match exists
  return primary.map(baseObj => {
    const id = String(baseObj?.[joinKey]);
    const updateData = secondaryMap.get(id);
    
    if (updateData) {
      return { ...baseObj, ...updateData };
    }
    return baseObj;
  });
}

