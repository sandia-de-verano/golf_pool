function createDgToEspnMap(rawLookupValues) {
  const DG_ID_COL_INDEX = 1; // Column B (Index 1)
  const ESPN_ID_COL_INDEX = 0; // Column A (Index 0)
  
  const dgToEspnMap = {};
  
  // Start from row 1 to skip the header row (index 0)
  for (let i = 1; i < rawLookupValues.length; i++) {
    const row = rawLookupValues[i];
    
    const dgId = row[DG_ID_COL_INDEX].toString();
    const espnId = row[ESPN_ID_COL_INDEX].toString();
    
    // Check if both IDs exist (not null/undefined/empty string after conversion)
    if (dgId && espnId) {
      dgToEspnMap[dgId] = espnId;
    }
  }
  
  return dgToEspnMap;
}

function createEspnToDgMap(rawLookupValues) {
  const DG_ID_COL_INDEX = 1; // Column B (Index 1)
  const ESPN_ID_COL_INDEX = 0; // Column A (Index 0)
  
  const espnToDgMap = {};
  
  // Start from row 1 to skip the header row (index 0)
  for (let i = 1; i < rawLookupValues.length; i++) {
    const row = rawLookupValues[i];

    // Explicitly convert IDs to strings before using them
    const dgId = row[DG_ID_COL_INDEX].toString();
    const espnId = row[ESPN_ID_COL_INDEX].toString();
    
    // Check if both IDs exist
    if (dgId && espnId) {
      espnToDgMap[espnId] = dgId;
  }
  }
  return espnToDgMap;
}

function mergeArrayData(primaryDataArray, dgToEspnMap, espnToDgMap, mergeOn) {
  let newHeader;
  let lookupMap; 
  
  if (mergeOn === 'id_athlete_espn') {
    newHeader = 'id_athlete_dg';
    lookupMap = espnToDgMap;
  } else if (mergeOn === 'id_athlete_dg') {
    newHeader = 'id_athlete_espn';
    lookupMap = dgToEspnMap;
  } else {
    Logger.log(`Error: 'mergeOn' parameter must be 'id_athlete_espn' or 'id_athlete_dg'. Received: ${mergeOn}`);
    return primaryDataArray;
  }

  // Check if lookupMap itself is undefined before starting the loop
  if (!lookupMap) {
    Logger.log("Error: lookupMap is undefined. Check if mapping objects are being passed correctly.");
    return primaryDataArray;
  }

  for (const rowObject of primaryDataArray) {
    const rawSourceId = rowObject[mergeOn];
    const sourceId = rawSourceId ? rawSourceId.toString() : '';

    // FIX: Check if the sourceId exists as a key in the map
    if (sourceId && lookupMap.hasOwnProperty(sourceId)) {
      rowObject[newHeader] = lookupMap[sourceId];
    } else {
      rowObject[newHeader] = ''; // Default to empty if not found
      // Optional: Log only once or selectively to avoid flooding logs
      // Logger.log(`Warning: ID ${sourceId} not found in map.`);
    }
  }

  return primaryDataArray;
}

