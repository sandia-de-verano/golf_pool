/**
 * Returns the current event configuration from the lookup sheet.
 * Consolidates the logic from getCurrentEvent, getCurrentEvent_2, and getCurrentEvent_3.
 */
function getCurrentEvent(sheet) {
  const cacheKey = "current_event_data";
  const cachedData = cache.get(cacheKey); // cache is defined in 0_config_constants

  if (cachedData) {
    return JSON.parse(cachedData);
  }

  try {
    const data = sheet.getDataRange().getValues();
      if (data.length <= 1) return null;

      const headers = data[0];
      const values = data.slice(1);
      
      // Create a Map where the key is the 'tourItem' status (e.g., 'current')
      const eventMap = new Map(values.map(row => {
        const obj = headers.reduce((acc, header, idx) => {
          acc[header] = row[idx];
          return acc;
        }, {});
        return [obj.tourItem, obj];
      }));
    const currentEvent = eventMap.get('current') || null;
    
    if (currentEvent && currentEvent.url_event) {
      // Store in cache for 1 hour (3600 seconds)
      cache.put(cacheKey, JSON.stringify(currentEvent), 14300);
      return currentEvent;
    }

    return null;
  } catch (e) {
    Logger.log(`Error reading data: ${e.message}`);
    return null;
  }
}

