function getAthleteIdMaps() {
  const cacheKeyBase = "athlete_id_maps_chunk_";
  const manifestKey = "athlete_id_maps_manifest";
  
  // 1. Check for the manifest (tells us how many chunks to look for)
  const manifest = cache.get(manifestKey);
  
  if (manifest) {
    const totalChunks = parseInt(manifest);
    let fullString = "";
    for (let i = 0; i < totalChunks; i++) {
      fullString += cache.get(cacheKeyBase + i) || "";
    }
    if (fullString) return JSON.parse(fullString);
  }

  // 2. If not in cache, build the maps from the sheet
  const lookupValues = SHT_LOOKUP_ATHLETES_ESPN_DG.getDataRange().getValues();
  const maps = {
    dgToEspn: createDgToEspnMap(lookupValues),
    espnToDg: createEspnToDgMap(lookupValues)
  };

  // 3. Chunk the stringified data (using ~50KB per chunk to be safe)
  const jsonString = JSON.stringify(maps);
  const chunkSize = 50000; 
  const chunks = [];
  
  for (let i = 0; i < jsonString.length; i += chunkSize) {
    chunks.push(jsonString.substring(i, i + chunkSize));
  }

  // 4. Store chunks and the manifest (max 6 hours / 21600 seconds)
  chunks.forEach((chunk, index) => {
    cache.put(cacheKeyBase + index, chunk, 21600);
  });
  cache.put(manifestKey, chunks.length.toString(), 21600);

  return maps;
}

