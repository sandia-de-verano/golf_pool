function get_baseline_data() {
 const currentEvent = getCurrentEvent(SHT_LOOKUPTOURNAMENT);
  const { dgToEspn, espnToDg } = getAthleteIdMaps();
  const athlete_data = global.readSheetData(SHT_ATHLETES);
  const lookup_liv_players = SHT_LIV_PLAYERS.getRange(4,14,SHT_LIV_PLAYERS.getLastRow(),2).getValues()
    .filter(row => row[0] !== "" || row[1] !== "") // Optional: filter out empty rows
    .map(row => ({ 
      id_athlete_espn: String(row[0]), 
      id_athlete_dg: String(row[1]), 
      active_LIV_player: 'yes' 
    }));

  // 1. Define all URLs
  const urls = {
    ranks: `${SOURCEURL_DG}${ENDPT_PRD_RANKS}?${FILEFORMAT}${API_DG}`,
    field: `${SOURCEURL_DG}${ENDPT_FIELD_UPDATES}?${FILEFORMAT}${API_DG}`,
    decomp: `${SOURCEURL_DG}${ENDPT_PRD_PLYR_DECOMP}?${FILEFORMAT}${API_DG}`,
    preTour: `${SOURCEURL_DG}${ENDPT_PRD_PRE_TOUR}?${FILEFORMAT}${API_DG}`,
    skills: `${SOURCEURL_DG}${ENDPT_PRD_SKILL_RATE}?display=rank&${FILEFORMAT}${API_DG}`,
    espn: getEspnRankingsUrl() 
  };

  // 2. Prepare concurrent requests
  const requests = [
    { url: urls.ranks, method: 'GET', muteHttpExceptions: true }, // Index 0
    { url: urls.field, method: 'GET', muteHttpExceptions: true }, // Index 1
    { url: urls.decomp, method: 'GET', muteHttpExceptions: true }, // Index 2
    { url: urls.preTour, method: 'GET', muteHttpExceptions: true }, // Index 3
    { url: urls.skills, method: 'GET', muteHttpExceptions: true }  // Index 4
  ];
  if (urls.espn) requests.push({ url: urls.espn, method: 'GET', muteHttpExceptions: true }); // Index 5

  const responses = UrlFetchApp.fetchAll(requests);

  // 3. Parse all responses using the new functions
  const dgRanksRaw = responses[0].getResponseCode() === 200 ? parseDgRankData(responses[0].getContentText()) : [];
  const fieldUpdates = responses[1].getResponseCode() === 200 ? parseDgFieldUpdates(responses[1].getContentText(), currentEvent) : [];
  const playerDecomp = responses[2].getResponseCode() === 200 ? parseDgPlayerDecomp(responses[2].getContentText()) : [];
  const preTourData = responses[3].getResponseCode() === 200 ? parseDgPreTourData(responses[3].getContentText()) : [];
  const skillRatings = responses[4].getResponseCode() === 200 ? parseDgSkillRatings(responses[4].getContentText()) : [];
  const espnRanksRaw = (urls.espn && responses[5]?.getResponseCode() === 200) ? parseEspnRankData(responses[5].getContentText()) : [];

  // 4. Perform efficient merges using the Generic Merge utility
  let rankings_map = mergeArrayData(dgRanksRaw, dgToEspn, espnToDg, 'id_athlete_dg');
  let rankings_espn = merge_data(rankings_map, espnRanksRaw, 'id_athlete_espn');
  let rankings_with_liv = merge_data(rankings_espn, lookup_liv_players, 'id_athlete_dg');
  let rankings_final = add_selection_name_LIV(rankings_with_liv, lookup_liv_players);

  console.log(rankings_final[1])

  // Save Rankings
  SHT_RANKINGS.clearContents();
  global.setValues_keys(rankings_final, SHT_RANKINGS);

  // 5. Merge Event-Specific Data
  let mergedData = merge_data(fieldUpdates, playerDecomp, 'id_athlete_dg');
  mergedData = merge_data(mergedData, preTourData, 'id_athlete_dg');
  mergedData = merge_data(mergedData, skillRatings, 'id_athlete_dg');
  mergedData = merge_data(mergedData, athlete_data, 'id_athlete_espn');
  mergedData = merge_data(mergedData, rankings_final, 'id_athlete_dg');

  const final_dataset = add_selection_name_LIV(mergedData, lookup_liv_players)
    .filter(item => item.id_event_dg !== undefined && item.id_event_dg !== '')
    .sort((a, b) => a.adjusted_rank - b.adjusted_rank);

  // 6. Final Save
  SHT_PLAYERDATA.clearContents();
  global.setValues_keys(final_dataset, SHT_PLAYERDATA);
}

function get_dg_rankings_v2(dgToEspn,espnToDg) {

  const headers = ['id_athlete_dg','player_name', 'owgr_rank',	'datagolf_rank', 'primary_tour',	'isAmateur',	'country',	'skill_estimate']
 
  const endpoint = `${SOURCEURL_DG}${ENDPT_PRD_RANKS}?${FILEFORMAT}${API_DG}`;

    // --- 1. Fetch Data ---
  let data;
  try {
    const response = UrlFetchApp.fetch(endpoint, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) {
      throw new Error(`HTTP Error ${response.getResponseCode()}`);
    }
    data = JSON.parse(response.getContentText());
  } catch (e) {
    console.log(`Failed to fetch DataGolf rankings: ${e.message}`);
    return;
  }

  // --- 2. Process Data ---
  const dataset = [];
  const rankings = data.rankings || [];

  for (const rank of rankings) {
    const newNormalizedName = swapNameOrder(rank.player_name);

    dataset.push([
      rank.dg_id ?? '',
      newNormalizedName,
      rank.owgr_rank,
      rank.datagolf_rank,
      rank.primary_tour ?? '',
      rank.am ?? '',
      rank.country ?? '',
      rank.dg_skill_estimate ?? '',
    ]);
  }

  // --- 3. Batch Write Results ---
  
  const outputArray = dataset.map(row => {
    let obj = {};
    headers.forEach((header, index) => {
      // Convert date strings to Date objects for easy comparison
      if (header.toLowerCase().includes('date')) {
        obj[header] = row[index] ? new Date(row[index]) : null;
      } else {
        obj[header] = row[index];
      }
    });
    return obj;
  });

  const finalArray = mergeArrayData(outputArray, dgToEspn, espnToDg, 'id_athlete_dg')

  return finalArray

}

function add_selection_name_LIV(rankings_dataset,liv_players){
      
      const dataset_combinedValue = rankings_dataset.map(athlete => {
          const current_rank = athlete.owgr_rank || '501';
          const current_rank_dg = athlete.datagolf_rank  || '501';
          const isActiveLIV = athlete.active_LIV_player === 'yes';
          const containsLIV = athlete.league ? athlete.league.toLowerCase().includes('liv') : false;
  
          let adjusted_rank;
          let rank_flag;
         if (current_rank_dg < current_rank && isActiveLIV && containsLIV) {
            adjusted_rank = current_rank_dg; 
            rank_flag = 'adj'
          } 
          // Logic 2: League contains 'liv' but NOT an active player -> Max of ranks
          else if (current_rank_dg < current_rank) {
            adjusted_rank = current_rank_dg;
            rank_flag = 'adj'
          } 
          // Logic 3: Everything else (does not contain liv AND not active) -> use current_rank
          else {
            adjusted_rank = current_rank;
            rank_flag = 'owgr'
          }

          if (!('fullName' in athlete)) { //fullName full_name
              const newNormalizedName = swapNameOrder(athlete.player_name);
              combinedValue = `${adjusted_rank} - ${newNormalizedName}`;
            } else {
              combinedValue = `${adjusted_rank} - ${athlete.fullName}`;
            }
          
          return {
            ...athlete, // Copy all existing properties from the athlete object
            owgr_rank: current_rank,
            datagolf_rank: current_rank_dg,
            playerSelection_name: combinedValue, // Add the new property
            adjusted_rank: adjusted_rank,
            rank_flag: rank_flag,
            //isActiveLIV: isActiveLIV,
          }
        });

  return dataset_combinedValue

}

