function get_dg_rankings_v2(dgToEspnMap,espnToDgMap) {

  const headers = ['id_athlete_dg','player_name', 'owgr_rank',	'datagolf_rank', 'primary_tour',	'isAmateur',	'country',	'skill_estimate']
 
  const endpoint = `${SOURCEURL_DG}${ENDPT_PRD_RANKS}?${FILEFORMAT}${API_DG}`;

    // --- 1. Fetch Data ---
  let data;
  try {
    const response = UrlFetchApp.fetch(endpoint, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) {
      throw new Error(`HTTP Error ${response.getResponseCode()}`);
    }
    data = JSON.parse(response.getContentText());
  } catch (e) {
    console.log(`Failed to fetch DataGolf rankings: ${e.message}`);
    return;
  }

  // --- 2. Process Data ---
  const dataset = [];
  const rankings = data.rankings || [];

  for (const rank of rankings) {
    const newNormalizedName = swapNameOrder(rank.player_name);

    dataset.push([
      rank.dg_id ?? '',
      newNormalizedName,
      rank.owgr_rank,
      rank.datagolf_rank,
      rank.primary_tour ?? '',
      rank.am ?? '',
      rank.country ?? '',
      rank.dg_skill_estimate ?? '',
    ]);
  }

  // --- 3. Batch Write Results ---
  
  const outputArray = dataset.map(row => {
    let obj = {};
    headers.forEach((header, index) => {
      // Convert date strings to Date objects for easy comparison
      if (header.toLowerCase().includes('date')) {
        obj[header] = row[index] ? new Date(row[index]) : null;
      } else {
        obj[header] = row[index];
      }
    });
    return obj;
  });

  const finalArray = mergeArrayData(outputArray, dgToEspnMap, espnToDgMap, 'id_athlete_dg')

  return finalArray

}

function add_selection_name_LIV(rankings_dataset,liv_players){
      
      const dataset_combinedValue = rankings_dataset.map(athlete => {
          const current_rank = athlete.owgr_rank || '501';
          const current_rank_dg = athlete.datagolf_rank  || '501';
          const isActiveLIV = athlete.active_LIV_player === 'yes';
          const containsLIV = athlete.league ? athlete.league.toLowerCase().includes('liv') : false;
  
          let adjusted_rank;
          let rank_flag;
         if (current_rank_dg < current_rank && isActiveLIV && containsLIV) {
            adjusted_rank = current_rank_dg; 
            rank_flag = 'adj'
          } 
          // Logic 2: League contains 'liv' but NOT an active player -> Max of ranks
          else if (current_rank_dg < current_rank) {
            adjusted_rank = current_rank_dg;
            rank_flag = 'adj'
          } 
          // Logic 3: Everything else (does not contain liv AND not active) -> use current_rank
          else {
            adjusted_rank = current_rank;
            rank_flag = 'owgr'
          }

          if (!('full_name' in athlete)) {
              const newNormalizedName = swapNameOrder(athlete.player_name);
              combinedValue = `${adjusted_rank} - ${newNormalizedName}`;
            } else {
              combinedValue = `${adjusted_rank} - ${athlete.fullName}`;
            }
          
          return {
            ...athlete, // Copy all existing properties from the athlete object
            owgr_rank: current_rank,
            datagolf_rank: current_rank_dg,
            playerSelection_name: combinedValue, // Add the new property
            adjusted_rank: adjusted_rank,
            rank_flag: rank_flag,
            isActiveLIV: isActiveLIV,
          }
        });

  return dataset_combinedValue

}

