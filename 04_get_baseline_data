function getEspnRankingsUrl() {
  const league = 'all';
  const dataType = 'rankings';
  const dataType2 = '1';
  const endpoint = `${SOURCEURL_ESPN}/v2/sports/${SPORT}/leagues/${league}/seasons/${YEAR}/${dataType}/${dataType2}/dates`;

  try {
    const response = UrlFetchApp.fetch(endpoint, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) return null;
    
    const data = JSON.parse(response.getContentText());
    return data.items?.[0]?.$ref || null;
  } catch (e) {
    console.log(`Failed to find ESPN rankings URL: ${e.message}`);
    return null;
  }
}

/**
 * Phase 2: Parses the raw JSON response from ESPN into your standard format.
 */
function parseEspnRankData(jsonContent) {
  const headers = ['id_athlete_espn', 'current_rank', 'prior_rank', 'rank_trend', 'total_points', 'gained_points', 'lost_points', 'average_points', 'total_events'];
  const ATHLETE_ID_REGEX = /athletes\/(\d+)/;
  
  const data = JSON.parse(jsonContent);
  const rankData = data.ranks || [];
  const dataset = [];

  for (const temp of rankData) {
    let athlete_id = '';
    const athleteRef = temp.athlete?.$ref;
    if (athleteRef) {
      const match = athleteRef.match(ATHLETE_ID_REGEX);
      athlete_id = match ? match[1] : '';
    }

    const stats = temp.record?.stats || [];
    dataset.push([
      athlete_id, 
      temp.current ?? '', 
      temp.previous ?? '', 
      temp.trend ?? '',
      stats[0]?.value ?? '', // totalPoints
      stats[1]?.value ?? '', // gainedPoints
      stats[2]?.value ?? '', // lostPoints
      stats[3]?.value ?? '', // averagePoints
      stats[4]?.value ?? ''  // totalEvents
    ]);
  }

  return dataset.map(row => {
    let obj = {};
    headers.forEach((header, idx) => obj[header] = row[idx]);
    return obj;
  });
}



