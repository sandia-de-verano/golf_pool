function swapNameOrder(fullName) {
  // Check if the input is a string and contains a comma separator
  if (typeof fullName !== 'string' || !fullName.includes(',')) {
    // If not in the expected format (no comma), return the original input
    return fullName;
  }

  // 1. Split the string at ALL commas. 
  // Example: "Smith, John, Jr." -> ["Smith", " John", " Jr."]
  var parts = fullName.split(',');

  // The function requires at least two parts (Last Name and First Name)
  if (parts.length < 2) {
    return fullName;
  }
  
  // 2. The Last Name is always the first part (and we remove it from the array).
  //    .shift() removes the first element and returns it. We trim() to clean spaces.
  var lastName = parts.shift().trim(); 

  // 3. Trim all remaining parts (First Name, Middle Name, Suffix, etc.)
  //    .map() creates a new array where all elements have been trimmed.
  var remainingParts = parts.map(function(part) {
    return part.trim();
  });
  // Example: [" John", " Jr."] becomes ["John", "Jr."]

  // 4. Join the remaining parts back together with a single space separator.
  var firstNameAndOtherNames = remainingParts.join(' '); 
  // Example: "John Jr."

  // 5. Recombine them in the desired order: "First Name Other Names Last Name"
  var newName = firstNameAndOtherNames + ' ' + lastName;
  
  return newName;
}

function get_espn_rankings_v2() {

  const headers = ['id_athlete_espn',	'current_rank',	'prior_rank','rank_trend', 'total_points',	'gained_points',	'lost_points',	'average_points',	'total_events']

  const league = 'all'
  const dataType = 'rankings'
  const dataType2 = '1'

  const endpoint = `${SOURCEURL_ESPN}/v2/sports/${SPORT}/leagues/${league}/seasons/${YEAR}/${dataType}/${dataType2}/dates`;

  // --- 2. Fetch Latest Week URL ---
  let week_url;
  try {
    let response = UrlFetchApp.fetch(endpoint, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) {
      throw new Error(`HTTP Error ${response.getResponseCode()} on main endpoint.`);
    }
    const data = JSON.parse(response.getContentText());
    
    // Safely get the latest week's reference URL
    week_url = data.items?.[0]?.$ref;
    if (!week_url) {
      console.log("Error: Could not find latest week URL in rankings endpoint response.");
      return;
    }
  } catch (e) {
    console.log(`Failed to fetch initial ranking endpoint: ${e.message}`);
    return;
  }

  // --- 3. Fetch Weekly Rankings Data ---
  let rankData;
  
  try {
    let response = UrlFetchApp.fetch(week_url, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) {
      throw new Error(`HTTP Error ${response.getResponseCode()} on weekly URL.`);
    }
    const data = JSON.parse(response.getContentText());
    rankData = data.ranks || [];

  } catch (e) {
    console.log(`Failed to fetch weekly rankings data: ${e.message}`);
    return;
  }

  // --- 4. Process Ranking Entries ---
  const dataset = [];
  const ATHLETE_ID_REGEX = /athletes\/(\d+)/;

  for (const temp of rankData) {
    const current = temp.current ?? '';
    const previous = temp.previous ?? '';
    const trend = temp.trend ?? '';
    
    // Extract athlete ID using regex
    let athlete_id = '';
    const athleteRef = temp.athlete?.$ref;
    if (athleteRef) {
      const match = athleteRef.match(ATHLETE_ID_REGEX);
      athlete_id = match ? match[1] : '';
    }

    // Safely extract stats
    const stats = temp.record?.stats || [];
    
    // Assuming the stats are always in the same order as your original script:
    const totalPoints = stats[0]?.value ?? '';
    const gainedPoints = stats[1]?.value ?? '';
    const lostPoints = stats[2]?.value ?? '';
    const averagePoints = stats[3]?.value ?? '';
    const totalEvents = stats[4]?.value ?? '';

    // Push the final data row
    dataset.push([
      athlete_id, current, previous, trend, 
      totalPoints, gainedPoints, lostPoints, averagePoints, totalEvents
    ]);
  }

	const dataArray = dataset.map(row => {
    let obj = {};
    headers.forEach((header, index) => {
      // Convert date strings to Date objects for easy comparison
      if (header.toLowerCase().includes('date')) {
        obj[header] = row[index] ? new Date(row[index]) : null;
      } else {
        obj[header] = row[index];
      }
    });
    return obj;
  });

  return dataArray

}
