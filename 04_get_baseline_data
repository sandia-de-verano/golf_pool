/** Parses DG Rankings */
function parseDgRankData(jsonContent) {
  const data = JSON.parse(jsonContent);
  const rankings = data.rankings || [];
  return rankings.map(rank => ({
    id_athlete_dg: rank.dg_id ?? '',
    fullName: swapNameOrder(rank.player_name),
    owgr_rank: rank.owgr_rank,
    datagolf_rank: rank.datagolf_rank,
    primary_tour: rank.primary_tour ?? '',
    isAmateur: rank.am ?? '',
    country: rank.country ?? '',
    skill_estimate: rank.dg_skill_estimate ?? ''
  }));
}

/** Parses DG Field Updates */
function parseDgFieldUpdates(jsonContent, currentEvent) {
  const data = JSON.parse(jsonContent);
  const field = data.field || [];
  return field.map(player => ({
    id_athlete_dg: player.dg_id ?? '',
    id_event_dg: data.event_id ?? '',
    tournamentName: data.event_name ?? '',
    isAmateur: player.am ?? '',
    early_late: player.early_late ?? '',
    pga_number: player.pga_number ?? '',
    start_hole: player.start_hole ?? '',
    course: player.course ?? '',
    id_tournament: currentEvent.id_tournament,
    id_event: currentEvent.id_event,
    year: currentEvent.year,
    league: currentEvent.league
  }));
}

/** Parses DG Player Decomposition */
function parseDgPlayerDecomp(jsonContent) {
  const data = JSON.parse(jsonContent);
  return (data.players || []).map(player => ({
    id_athlete_dg: String(player.dg_id),
    players_final_pred: player.final_pred ?? ''
  }));
}

