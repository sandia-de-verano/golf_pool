function calculateGolfWinnings(players,prizeMap,tournamentStarted) {

  const existingRanks = players
    .map(p => parseInt((p.adjusted_rank || "").toString().replace(/[^0-9]/g, "")))
    .filter(r => !isNaN(r))
    .sort((a, b) => a - b);

  const uniqueRanks = [...new Set(existingRanks)];
  
  // Create a map
  const rankMap = {};
  uniqueRanks.forEach((rawRank, index) => {
    rankMap[rawRank] = index + 1;
  });

  // 2. Update players to use Adjusted Rank if original is blank
  players.forEach(player => {
    const rawRank = parseInt((player.current_position || '').toString().replace(/[^0-9]/g, ""));
    const uncut_rank = player.current_position

    if (uncut_rank === "CUT" || uncut_rank === "WD" || uncut_rank === "DQ") {
      player.effective_rank = 0;
    } else if (isNaN(rawRank) || rawRank === undefined || rawRank === null || rawRank === '' ) {         
      player.effective_rank = tournamentStarted ? 0 : rankMap[player.adjusted_rank]
      //player.effective_rank = rankMap[player.adjusted_rank] || 0;
    } else {
      player.effective_rank = rawRank;
    }

  });

  // 3. Count occurrences of the EFFECTIVE rank (for tie logic)
  const positionCounts = players.reduce((acc, player) => {
    if (player.effective_rank) {
      acc[player.effective_rank] = (acc[player.effective_rank] || 0) + 1;
    }
    return acc;
  }, {});

  // 4. Calculate winnings based on the effective rank  // 4. Calculate winnings based on the effective rank
  players.forEach((player) => {
    const startRank = player.effective_rank;

    if (!startRank) {
      player.projected_earnings = 0;
      return;
    }

    const count = positionCounts[startRank];

    if (count > 1) {
      // TIE LOGIC
      let totalTiePool = 0;
      for (let i = 0; i < count; i++) {
        totalTiePool += (prizeMap[startRank + i] || 0);
      }
      player.projected_earnings = totalTiePool / count;
    } else {
      // SOLO LOGIC
      player.projected_earnings = prizeMap[startRank] || 0;
    }
  });

  return players;
}

