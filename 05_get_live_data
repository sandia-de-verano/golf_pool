// ----------------------------------------------------------------------------------
function calculateGolfWinnings(players, prizeMap) {
  if (!players || players.length === 0) return [];

  // 1. Group players by their score to identify ties
  const tiedGroups = [];
  let currentGroup = [players[0]];

  for (let i = 1; i < players.length; i++) {
    if (players[i].current_score === players[i - 1].current_score) {
      currentGroup.push(players[i]);
    } else {
      tiedGroups.push(currentGroup);
      currentGroup = [players[i]];
    }
  }
  tiedGroups.push(currentGroup); // Push the final group

  // 2. Assign ranks and earnings based on group size
  let currentRank = 1;
  
  tiedGroups.forEach(group => {
    const groupSize = group.length;
    let averageEarnings = 0;

    // Check if players in this group are disqualified or cut
    const isOut = group[0].current_position === "CUT" || 
                  group[0].current_position === "WD" || 
                  group[0].current_position === "DQ";

    if (!isOut) {
      // Tie Logic: Sum prizes for all slots this group occupies and average them
      let totalTiePool = 0;
      for (let i = 0; i < groupSize; i++) {
        totalTiePool += (prizeMap[currentRank + i] || 0);
      }
      averageEarnings = totalTiePool / groupSize;
    }

    // Apply calculated values to every player in the tie-group
    group.forEach(player => {
      player.effective_rank = isOut ? 0 : currentRank;
      player.projected_earnings = averageEarnings;
    });

    // Increment rank by the number of players in the group (e.g., 3 players at T1 means next rank is 4)
    currentRank += groupSize;
  });

  return players;
}

