function checkRecentUpdates(dataArray) {
  const now = new Date().getTime(); // Current time in ms
  const oneHour = 60 * 60 * 1000;   // 3,600,000 ms

  const recentlyUpdated = dataArray.filter(item => {
    // Convert the stored string or date object back into a timestamp
    const updatedTime = new Date(item.last_updated).getTime();
    
    // Check if the time difference is less than 1 hour
    return (now - updatedTime) < oneHour;
  });

  let status
  if (recentlyUpdated.length > 0) {
    status = true
    console.log(`${recentlyUpdated.length} items were updated in the last hour.`);
  } else {
    status = false
    console.log("No items updated recently.");
  }
  return status
}

function checkDateStatus(target_date) {
  const today = new Date();
  
  // Ensure targetDate is a Date object, even if a string was passed
  const targetDate = new Date(target_date);

  // Check if the date is valid before calling .getTime()
  if (isNaN(targetDate.getTime())) {
    console.error("Invalid date passed to checkDateStatus:", target_date);
    return false; 
  }

  let date_status;
  if (today.getTime() < targetDate.getTime()) {
    date_status = true; // Today is BEFORE the target date
  } else {
    date_status = false; // Target date has passed or is today
  }

  return date_status;
}

function isUpdateNeeded(dataArray, minutes) {
  if (!dataArray || dataArray.length === 0) return true;
  
  const now = new Date().getTime();
  const threshold = minutes * 60 * 1000;

  // Check the last_updated field of the first item
  const lastUpdateStr = dataArray[0].last_updated;
  if (!lastUpdateStr) return true;

  const lastUpdateTime = new Date(lastUpdateStr).getTime();
  return (now - lastUpdateTime) > threshold;
}
