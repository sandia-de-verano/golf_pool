function leaderboard_flow () {
  const currentEvent = getCurrentEvent(SHT_LOOKUPTOURNAMENT);
  if (!currentEvent) return;

  const leaderboard = global.readSheetData(SHT_VIEW_LEADERBOARD);
    if (!leaderboard || leaderboard.length === 0) return;

let earn_flag = (leaderboard.length > 0) ? (leaderboard[0].earn_flag || '') : '';

// Recognize both final states to stop the script
if (earn_flag === 'final' || earn_flag === 'final_non_pool') {
      console.log('Tournament is already complete.');
      return; 
  }

  const is_ongoing = checkDateStatus(currentEvent.adj_end_date); // true if before end date

  if (is_ongoing) {
    console.log('Running live updates.');
    get_live_data_again(); 
  } else {
    console.log('Tournament over: checking ESPN for final earnings.');
    get_final_earnings();
  }
}


