function get_final_earnings() {

   const currentEvent = getCurrentEvent(SHT_LOOKUPTOURNAMENT);
      if (!currentEvent) return;
      const id_event = currentEvent.id_event.toString()
			const id_tournament = currentEvent.id_tournament.toString()
      const url_event = currentEvent.url_event
			const year = currentEvent.year

  const player_live_raw = global.readSheetData(SHT_PLAYERLIVE);

  const prj_earn_table_raw = SHT_PROJ_EARNINGS_TABLE.getRange(1,8,SHT_PROJ_EARNINGS_TABLE.getLastRow(),2).getValues();
    const prj_earn_table_values = prj_earn_table_raw.slice(1);
    const prj_earn_table_headers = ['order','projected_earnings'];

  let prj_earn_table
    prj_earn_table = add_keys(prj_earn_table_values,prj_earn_table_headers)
    prj_earn_table = prj_earn_table.filter(obj => obj.order.toString().trim() !== '');

  const prizeMap = prj_earn_table.reduce((acc, curr) => {
    acc[curr.order] = curr.projected_earnings;
    return acc;
  }, {});

  let athlete_info = [];

    const eventResponse = UrlFetchApp.fetch(url_event, { muteHttpExceptions: true });
    const eventData = JSON.parse(eventResponse.getContentText());
    const competitorsSummary = eventData.competitions?.[0]?.competitors || [];

    if (eventData?.status?.type?.name != 'STATUS_FINAL' ) {
      console.log('Event not final');
      return; 
    } 

// --------------------------------

    for (const comp of competitorsSummary) {
      
			const id_athlete_espn = comp.id.toString();
			const earnings = comp.earnings || 0;
      
      athlete_info.push([id_athlete_espn,earnings])
    }

    headers_ath_info = [
			'id_athlete_espn',
      'earnings'
    ];

  ath_info_keys = add_keys(athlete_info,headers_ath_info)

// ------------------------------------


  const finalDataset = merge_live_data_espn_id(player_live_raw,ath_info_keys)

    const finalDataset_time_stamp = finalDataset.map(item => ({
      ...item, // This "spreads" the existing keys (name, earnings, etc.)
      last_data_pull: new Date().getTime() // Adds the new one
    }));

    finalDataset_time_stamp.sort((a, b) => a.adjusted_rank - b.adjusted_rank);
    finalDataset_time_stamp.sort((a, b) => a.current_score - b.current_score);

  SHT_TEST.clearContents();
  global.setValues_keys(finalDataset_time_stamp,SHT_TEST)

  //SHT_PLAYERLIVE.clearContents();
  //global.setValues_keys(finalDataset_time_stamp,SHT_PLAYERLIVE)

  update_pool_leaderboard()

}


function hist_parseDataESPN_results(dataArray) {
  const finalDataset = [];

  if (!dataArray || dataArray.length === 0) {
    return [];
  }

  for (let i = 0; i < dataArray.length; i++) {
    const item = dataArray[i];
    const sourceRow = item.source;
    const response = item.response;

    let data;
    try {
      data = JSON.parse(response.getContentText());
    } catch (e) {
      const errorMsg = `JSON Parsing error: ${e.toString()}`;
      console.error(`Error parsing JSON for ${sourceRow.url_event}: ${errorMsg}`);
      continue;
    }

    const id_athlete_espn = parseUrl_athlete(sourceRow).toString();
    const current_position = data.position?.displayName ? data.position?.displayName : ''
    const thru = data.thru? data.thru: ''
    const over_under_score = data.completedRoundsDisplayValue  ? data.completedRoundsDisplayValue : ''

    const rowData = [
      id_athlete_espn,
      current_position, 
      thru, 
      over_under_score,
    ];

    finalDataset.push(rowData);
  }

  headers = [
      'id_athlete_espn',
      'current_position', 
      'thru', 
      'current_score',
    ];

  const final_data_keys = add_keys(finalDataset,headers)

  const final_data_de_dup = mergeArrayById(final_data_keys,'id_athlete_espn')

  return final_data_de_dup;
}


