function processData(rawData) {
  const userMap = [];
  const EARNINGS_TYPES = ['s1', 's2', 's3', 'liv'];

  rawData.forEach(row => {
    const uid = row.UID;
    if (!userMap[uid]) {
      userMap[uid] = {
        UID: row.UID,
        user_name: row.user_name,
        id_event: row.id_event,
        year: row.year,
        tournament_name: row.tournament_name,
        totalEarnings: 0,
        earn_flag: row.earn_flag,
        data: {}
      };
    }

    if (EARNINGS_TYPES.includes(row.type)) {
      userMap[uid].totalEarnings += parseFloat(row.earnings || 0);
    }

    userMap[uid].data[row.type] = {
      id: String(row.id_athlete_espn),
      sub: row.sub,
      pos: row.position,
      name: row.fullName,
      thru: row.thru,
      score: row.score,
      earn: row.earnings,
    };
  });

  return Object.values(userMap);
}
