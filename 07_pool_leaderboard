function create_update_leaderboards() {
	const user_selection_data = global.readSheetData(SHT_USERSELECTION)

      const headers = [
      "UID", 
      "user_fullName", 
      'user_email', 
      'id_event', 
      "tournament_Name", 
      "S1_SUB", 
      "S2_SUB", 
      "S3_SUB", 
      "LIV_SUB", 
      "A1_S_SWAP", 
      "A2_S_SWAP", 
      "Player Selection 1", 
      "Player Selection 2", 
      "Player Selection 3", 
      "Player Selection LIV", 
      "Player Alternate 1", 
      "Player Alternate 2", 
      "Player Alternate LIV",
      'id_athlete_espn_s1',	
      'id_athlete_espn_s2',	
      'id_athlete_espn_s3',	
      'id_athlete_espn_liv',	
      'id_athlete_espn_alt1',	
      'id_athlete_espn_alt2',	
      'id_athlete_espn_alt_liv'];

  const finalOutputArray = [headers]
  const backgroundArray = [new Array(headers.length).fill(null)];

  user_selection_data.forEach((row) => {
    let s1_sub = "No", s2_sub = "No", s3_sub = "No", liv_sub = "No";
    let a1s_sub = "", a2s_sub = "";
    let rowColors = new Array(headers.length).fill(null); 

    // --- INITIALIZE CURRENT STATE ---
    // Start with the original data for this row
    let lineup = {
      s1: { name: cleanValue(row.selection1), id: row.id_athlete_espn_s1 },
      s2: { name: cleanValue(row.selection2), id: row.id_athlete_espn_s2 },
      s3: { name: cleanValue(row.selection3), id: row.id_athlete_espn_s3 },
      liv: { name: cleanValue(row.liv), id: row.id_athlete_espn_liv },
      a1: { name: cleanValue(row.alt1), id: row.id_athlete_espn_alt1 },
      a2: { name: cleanValue(row.alt2), id: row.id_athlete_espn_alt2 },
      aliv: { name: cleanValue(row.altLiv), id: row.id_athlete_espn_alt_liv }
    };

    // --- DEFINE THE SWAP FUNCTION ---
    const executeTrueSwap = (updatedKey, starterKey, slotLabel, nameCol, idCol) => {
      const updatedValClean = cleanValue(row[updatedKey]);
      const currentStarterClean = lineup[starterKey].name;

      if (updatedValClean && updatedValClean !== currentStarterClean) {
        
        let altSlotMatch = null;
        if (lineup.a1.name === updatedValClean) altSlotMatch = 'a1';
        else if (lineup.a2.name === updatedValClean) altSlotMatch = 'a2';
        else if (lineup.aliv.name === updatedValClean) altSlotMatch = 'aliv';

        if (altSlotMatch) {
          // Perform the Swap
          let tempStarter = { ...lineup[starterKey] };
          lineup[starterKey] = { ...lineup[altSlotMatch] }; // Alt moves to Starter
          lineup[altSlotMatch] = tempStarter;              // Starter moves to Alt

          // Update UI/Metadata Flags
          if (starterKey === 's1') s1_sub = "Yes";
          if (starterKey === 's2') s2_sub = "Yes";
          if (starterKey === 's3') s3_sub = "Yes";
          if (starterKey === 'liv') liv_sub = "Yes";
          
          if (altSlotMatch === 'a1') a1s_sub = slotLabel;
          if (altSlotMatch === 'a2') a2s_sub = slotLabel;

          // Highlight Starter Name/ID and Alt Name/ID
          const altNameCol = altSlotMatch === 'a1' ? 15 : (altSlotMatch === 'a2' ? 16 : 17);
          const altIdCol = altSlotMatch === 'a1' ? 22 : (altSlotMatch === 'a2' ? 23 : 24);
          
          [nameCol, idCol, altNameCol, altIdCol].forEach(idx => rowColors[idx] = "#d9ead3");
        }
      }
    };

  executeTrueSwap('updatedPick_s1', 's1', 'S1', 11, 18);
  executeTrueSwap('updatedPick_s2', 's2', 'S2', 12, 19);
  executeTrueSwap('updatedPick_s3', 's3', 'S3', 13, 20);
  executeTrueSwap('updatedPick_LIV', 'liv', 'LIV', 14, 21);

  const outputRow = [
      row.UID, row.user_fullName, row.user_email, row.id_event, row.tournamentName,
      s1_sub, s2_sub, s3_sub, liv_sub, a1s_sub, a2s_sub,
      lineup.s1.name, lineup.s2.name, lineup.s3.name, lineup.liv.name, // Updated Starters
      lineup.a1.name, lineup.a2.name, lineup.aliv.name,               // Updated Alts
      lineup.s1.id, lineup.s2.id, lineup.s3.id, lineup.liv.id,         // Updated Starter IDs
      lineup.a1.id, lineup.a2.id, lineup.aliv.id                     // Updated Alt IDs
    ];

    finalOutputArray.push(outputRow);
    backgroundArray.push(rowColors);
  });

  // 3. Write Data and Colors to Sheet
  if (finalOutputArray.length > 1) {
    SHT_UPDATE_USERSELECTIONS.clearContents();
    const range = SHT_UPDATE_USERSELECTIONS.getRange(1, 1, finalOutputArray.length, finalOutputArray[0].length);
    range.setValues(finalOutputArray);
    range.setBackgrounds(backgroundArray);
  }
}

function cleanValue(value) {
  if (!value || typeof value !== 'string') return value;
  
  // This regex looks for digits followed by a hyphen and space at the start
  // or simply splits by the first hyphen if found.
  if (value.includes(' - ')) {
    return value.split(' - ').slice(1).join(' - ').trim();
  }
  return value.trim();
}

