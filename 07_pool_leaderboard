function flattenData_v2(data) {
  data.sort((a, b) => b.totalEarnings - a.totalEarnings);

  // Assign Ranks
  data.forEach((user, i) => {
    if (i > 0 && user.totalEarnings === data[i - 1].totalEarnings) {
      user.rank = data[i - 1].rank;
    } else {
      user.rank = i + 1;
    }
  });

 const finalData = [];

  data.forEach(user => {

    const row = [
      user.UID, 
      user.id_event,
      user.year,
      user.tournament_name, 
      user.rank, 
      user.user_name, 
      user.totalEarnings,
      user.earn_flag
      
    ];

  // selections    
    const select_details = user.data; 
    const types = ['s1', 's2', 's3', 'liv', 'alt_1', 'alt_2', 'alt_liv'];
    // data for selections  
    
    types.forEach(type => {
      const typeData = select_details[type] ||{};
      row.push(
        typeData.id || '',
        typeData.sub || '',
        typeData.pos || '',
        typeData.name || '',
        typeData.thru || '',
        typeData.score || '',
        typeData.earn || 0,
      );
    })

  finalData.push(row)
  });

  return finalData
}

