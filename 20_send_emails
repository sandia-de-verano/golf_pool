function email_pool_open() {
  const currentEvent = getCurrentEvent(SHT_LOOKUPTOURNAMENT);

// --- Validation ---
    if (!currentEvent) return;
    if (!currentEvent.isPoolEvent) {console.log('Not Pool Event'); return};

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const lookup_date = new Date(currentEvent.pool_opens_date);
    lookup_date.setHours(0, 0, 0, 0);

    const isToday = today.getTime() === lookup_date.getTime();

  if (!isToday) {
    console.log("The deadline is not today. Skipping.");
    return; // Exit early if not today
  }
  console.log("The deadline is today! Sending emails...");

// --- get data ---

  const curr_event_name = currentEvent.tournamentName;
  const due_date = currentEvent.picks_due_date;
  const users = global.readSheetData(SHT_USERS)
    if (!users || users.length === 0) return;
    const columnHeaders = Object.keys(users[0]);
    const dateKey = 'pool_open_date_sent'; // <--- Ensure this matches your Sheet Header exactly
    const dateColIndex = columnHeaders.indexOf(dateKey) + 1;
      if (dateColIndex === 0) {
        console.log(`Warning: Column "${dateKey}" not found in SHT_USERS. Dates will not be recorded.`);
      }

  const subject = `⛳ Make Selections: ${curr_event_name} - Pool Open`;

  users.forEach(row => {
    let email = row.user_email.toString().toLowerCase().trim();
    let is_active = row.is_active;
    const alreadySentToday = row[dateKey] && new Date(row[dateKey]).toDateString() === new Date().toDateString();

    if (email && is_active && !alreadySentToday) {

      const htmlBody = `
        <p>Hello, amazing humans!</p> 
        <p>It's your friendly digital caddie, Hogan G. Wooodland! I'm here with a tee-rific reminder! 🏌️‍♂️</p>
        <p>Selections for ⛳ ${curr_event_name} are OPEN!</p>
        <p>Make your selections here: <a href='https://www.appsheet.com/start/730ac965-db6f-4e24-bed6-2d926750dee6'>Fairway Pool</a></p>
        <p>🌟 Deadline for updates is <b>${due_date}</b> 🌟</p>
        <br>
        <p>Sincerely,</p>
        <p><b>Team Fairway Pool</b><br>
        <font face="arial, sans-serif" size="2">General ne'er do wells, Attempted cat herders, and Agents of Chaos</font></p>
      `;
    
     MailApp.sendEmail({
        to: email,
        subject: subject,
        htmlBody: htmlBody
      });
        
        if (dateColIndex > 0) {
          SHT_USERS.getRange(index + 2, dateColIndex).setValue(new Date());
        }
        Logger.log("Reminder sent to: " + email);

      } else {
        //Logger.log("No reminder needed for: " + email);
      }
    });

}

